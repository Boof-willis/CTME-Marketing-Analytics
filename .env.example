# =============================================================================
# CTME Marketing Dashboard — environment configuration
# Copy this file to `.env.local` and fill in the values you have.
# The dashboard runs out-of-the-box with realistic DEMO data when keys are
# missing, so you can wire sources in one at a time.
# =============================================================================

# ----- Data mode -------------------------------------------------------------
# "demo"  -> always use generated sample data (great for design review)
# "live"  -> use real APIs where keys are present, demo data for the rest
# "auto"  -> (default) live for any source that has credentials, demo otherwise
DATA_MODE=auto

# ----- GoHighLevel (GHL) -----------------------------------------------------
# Private Integration token (Settings -> Private Integrations) OR an OAuth
# access token. The Location ID is the sub-account you are reporting on.
GHL_API_TOKEN=
GHL_LOCATION_ID=
# GHL API base. v2 is the current public API.
GHL_API_BASE=https://services.leadconnectorhq.com

# Tag / field configuration used to classify contacts.
# Comma-separated tag names (case-insensitive) that mark traffic source.
GHL_TAG_COLD=cold
GHL_TAG_WARM=warm
GHL_TAG_WEBSITE=website
# Tag OR custom-field used to flag a refund. If you migrate to a "refund"
# dropdown custom field, set GHL_REFUND_FIELD_KEY to its field key.
GHL_TAG_REFUND=refund
GHL_REFUND_FIELD_KEY=
# LTV is averaged from the GHL "Lifetime Value" custom field across contacts that
# have a real (non-zero) value. Defaults to CTME's field id; override if it differs.
GHL_LTV_FIELD_ID=ss1nwCf5rNtQpkShzMIC

# Calendar / appointment status mapping (GHL appointment statuses).
GHL_STATUS_COMPLETED=showed,confirmed,completed
GHL_STATUS_NOSHOW=noshow,no-show

# ----- Stripe ----------------------------------------------------------------
# Used for authoritative revenue, purchases, unique purchasers and refunds.
STRIPE_SECRET_KEY=

# ----- Meta (Facebook) Ads ---------------------------------------------------
# Option A (preferred per CTME): pull through the GHL Ads integration (leave
# these blank and the GHL source will surface spend if available).
# Option B: direct Meta Marketing API for reliable spend/CPC/CPM/impressions.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ----- Google Ads ------------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ----- Google Analytics 4 (Web Analytics view) ------------------------------
# Pulls sessions, users, channels, top pages and conversions via the GA4 Data
# API (REST). Auth is OAuth so the dashboard can be connected / reconnected from
# the UI: whoever clicks "Connect Google Analytics" owns the token, so the link
# survives a change of agency.
#
# Setup:
#   1. Google Cloud Console -> enable the "Google Analytics Data API".
#   2. APIs & Services -> Credentials -> Create OAuth client ID (Web application).
#      Add an Authorized redirect URI: https://<your-domain>/api/ga/callback
#      (and http://localhost:3000/api/ga/callback for local dev).
#   3. OAuth consent screen: add the connecting user as a Test user, or publish.
#   4. GA4 Admin -> Property Settings -> copy the numeric Property ID.
#   5. Deploy, open Web Analytics, click "Connect Google Analytics", sign in.
# Client id/secret fall back to the GOOGLE_ADS_* OAuth app if left blank.
GA4_PROPERTY_ID=
GA4_OAUTH_CLIENT_ID=
GA4_OAUTH_CLIENT_SECRET=
# Optional: only needed if the auto-derived callback URL is wrong (proxies, etc).
GA4_OAUTH_REDIRECT_URI=
# Optional seed: a pre-generated refresh token for the no-store case.
# Normally you connect via the UI instead and leave this blank.
GA4_REFRESH_TOKEN=

# ----- Upstash Redis (durable GA4 token storage) -----------------------------
# So the GA4 connection survives redeploys/restarts, the OAuth refresh token is
# persisted in Upstash (free tier is plenty). Create a database at
# https://console.upstash.com, then copy its REST URL + token here. If left
# blank, the token is held in memory only (you'd reconnect after each deploy).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- App security ----------------------------------------------------------
# Optional shared secret. If set, GHL must append ?k=THIS_VALUE to the embed
# URL or requests are rejected. Leave blank to disable.
DASHBOARD_ACCESS_KEY=
